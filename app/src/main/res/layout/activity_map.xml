<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootMap"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen">

    <include
        android:id="@+id/toolbarHost"
        layout="@layout/view_toolbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/topPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/screen_padding_h"
        android:layout_marginTop="6dp"
        android:layout_marginEnd="@dimen/screen_padding_h"
        android:background="@drawable/bg_map_panel"
        android:orientation="vertical"
        android:padding="@dimen/map_panel_padding"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbarHost"
        app:layout_constraintWidth_max="@dimen/content_max_width">

        <TextView
            android:id="@+id/tvMapSubtitle"
            style="@style/AppTextCardDesc"
            android:text="@string/map_panel_hint" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnAdminLogin"
                style="@style/AppButtonPrimaryDark"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:text="Админ"
                android:textSize="@dimen/text_button_small" />

            <Button
                android:id="@+id/btnAdminLogout"
                style="@style/AppButtonSecondaryDark"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:text="Выйти"
                android:textSize="@dimen/text_button_small" />
        </LinearLayout>
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/mapCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="@dimen/screen_padding_h"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="@dimen/screen_padding_h"
        android:layout_marginBottom="@dimen/screen_padding_bottom"
        app:cardBackgroundColor="@color/app_surface"
        app:cardCornerRadius="@dimen/corner_card"
        app:cardElevation="@dimen/card_elevation"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topPanel"
        app:strokeColor="@color/app_stroke"
        app:strokeWidth="1dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <org.osmdroid.views.MapView
                android:id="@+id/mapView"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <LinearLayout
                android:id="@+id/emptyState"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/app_surface"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="24dp"
                android:visibility="gone">

                <ImageView
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:contentDescription="@string/cd_icon_empty_map"
                    android:src="@drawable/ic_empty_map"
                    app:tint="@color/app_green" />

                <TextView
                    style="@style/AppTextSectionTitle"
                    android:layout_marginTop="16dp"
                    android:gravity="center"
                    android:text="@string/map_empty_title" />

                <TextView
                    style="@style/AppTextCardDesc"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:text="@string/map_empty_desc" />
            </LinearLayout>

            <include
                layout="@layout/view_map_legend"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|start"
                android:layout_marginStart="12dp"
                android:layout_marginBottom="12dp"
                android:clickable="false"
                android:focusable="false" />

            <include
                layout="@layout/panel_map_dump_detail" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabMyLocation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|end"
                android:layout_margin="16dp"
                android:contentDescription="@string/cd_my_location"
                app:backgroundTint="@color/app_green"
                app:srcCompat="@drawable/ic_pin"
                app:tint="@color/app_on_primary" />
        </FrameLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
