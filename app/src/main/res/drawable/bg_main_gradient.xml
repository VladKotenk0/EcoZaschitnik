<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/screen_bg" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="520dp"
                android:centerX="90%"
                android:centerY="8%"
                android:startColor="@color/screen_glow_accent"
                android:endColor="#00000000" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="480dp"
                android:centerX="10%"
                android:centerY="92%"
                android:startColor="@color/screen_glow_soft"
                android:endColor="#00000000" />
        </shape>
    </item>
</layer-list>
