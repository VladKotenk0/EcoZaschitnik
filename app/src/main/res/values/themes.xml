<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.EcoZaschitnik" parent="Theme.MaterialComponents.DayNight.NoActionBar">

        <item name="android:fontFamily">@font/comfortaa_family</item>
        <item name="fontFamily">@font/comfortaa_family</item>

        <item name="android:windowBackground">@color/app_bg</item>
        <item name="colorPrimary">@color/app_green</item>
        <item name="colorPrimaryVariant">@color/app_green_dark</item>
        <item name="colorAccent">@color/app_accent</item>

        <item name="android:statusBarColor">@color/app_status_bar</item>
        <item name="android:navigationBarColor">@color/app_nav_bar</item>

        <item name="android:textColor">@color/app_text</item>
        <item name="materialButtonStyle">@style/AppButton</item>
        <item name="textAppearanceHeadline6">@style/AppTitleText</item>
    </style>

    <style name="AppToolbarTitle" parent="TextAppearance.Widget.AppCompat.Toolbar.Title">
        <item name="android:textColor">@color/app_text</item>
        <item name="android:textSize">@dimen/text_screen_title_inner</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">@font/comfortaa_family</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:lineSpacingExtra">0dp</item>
        <item name="android:lineSpacingMultiplier">1</item>
    </style>

    <style name="AppTextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">@dimen/corner_input</item>
        <item name="boxCornerRadiusTopEnd">@dimen/corner_input</item>
        <item name="boxCornerRadiusBottomStart">@dimen/corner_input</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/corner_input</item>
        <item name="boxStrokeColor">@color/app_green</item>
        <item name="hintTextColor">@color/app_text_muted</item>
    </style>

    <style name="AppButton" parent="Widget.MaterialComponents.Button">
        <item name="android:backgroundTint">@color/app_green</item>
        <item name="cornerRadius">@dimen/corner_button</item>
        <item name="android:textColor">@color/app_on_primary</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:padding">12dp</item>
        <item name="android:fontFamily">@font/comfortaa_family</item>
    </style>

    <style name="AppTitleText" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textColor">@color/app_green</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">24sp</item>
        <item name="android:fontFamily">@font/comfortaa_family</item>
    </style>

    <style name="AppButtonHero" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/app_hero_button_bg</item>
        <item name="cornerRadius">@dimen/corner_button</item>
        <item name="android:textColor">@color/app_hero_button_text</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">@dimen/text_button</item>
        <item name="android:fontFamily">@font/comfortaa_family</item>
        <item name="android:gravity">center</item>
        <item name="android:minHeight">@dimen/button_min_height</item>
        <item name="android:paddingTop">@dimen/button_padding_v</item>
        <item name="android:paddingBottom">@dimen/button_padding_v</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:insetLeft">0dp</item>
        <item name="android:insetRight">0dp</item>
        <item name="android:maxLines">1</item>
        <item name="android:ellipsize">end</item>
    </style>

    <style name="AppButtonPrimaryDark" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/btn_primary_bg_tint</item>
        <item name="cornerRadius">@dimen/corner_button</item>
        <item name="android:textColor">@color/btn_primary_text</item>
        <item name="rippleColor">@color/app_ripple</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">@dimen/text_button</item>
        <item name="android:fontFamily">@font/comfortaa_family</item>
        <item name="android:gravity">center</item>
        <item name="android:minHeight">@dimen/button_min_height</item>
        <item name="android:paddingTop">@dimen/button_padding_v</item>
        <item name="android:paddingBottom">@dimen/button_padding_v</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:insetLeft">0dp</item>
        <item name="android:insetRight">0dp</item>
        <item name="android:maxLines">1</item>
        <item name="android:ellipsize">end</item>
        <item name="android:includeFontPadding">true</item>
    </style>

    <style name="AppButtonSecondaryDark" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="backgroundTint">@android:color/transparent</item>
        <item name="strokeColor">@color/app_green</item>
        <item name="strokeWidth">2dp</item>
        <item name="cornerRadius">@dimen/corner_button</item>
        <item name="android:textColor">@color/app_text</item>
        <item name="rippleColor">@color/app_ripple</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">@dimen/text_button</item>
        <item name="android:fontFamily">@font/comfortaa_family</item>
        <item name="android:gravity">center</item>
        <item name="android:minHeight">@dimen/button_min_height</item>
        <item name="android:paddingTop">@dimen/button_padding_v</item>
        <item name="android:paddingBottom">@dimen/button_padding_v</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:insetLeft">0dp</item>
        <item name="android:insetRight">0dp</item>
        <item name="android:maxLines">1</item>
        <item name="android:ellipsize">end</item>
    </style>

</resources>
